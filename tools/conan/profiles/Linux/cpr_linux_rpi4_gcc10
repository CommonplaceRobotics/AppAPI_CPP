[settings]
arch=armv8_32
build_type=Debug
compiler=gcc
compiler.cppstd=gnu17
compiler.libcxx=libstdc++11
compiler.version=10
os=Linux

[buildenv]
CC=/opt/gcc/armv8-rpi4-linux-gnueabihf/bin/armv8-rpi4-linux-gnueabihf-gcc
CXX=/opt/gcc/armv8-rpi4-linux-gnueabihf/bin/armv8-rpi4-linux-gnueabihf-g++
LD=/opt/gcc/armv8-rpi4-linux-gnueabihf/bin/armv8-rpi4-linux-gnueabihf-ld

[conf]
tools.cmake.cmaketoolchain:generator=Ninja

[options]
# Disabling unnecessary features to speed up compiling
grpc/*:csharp_ext=False
grpc/*:csharp_plugin=False
grpc/*:node_plugin=False
grpc/*:objective_c_plugin=False
grpc/*:otel_plugin=False
grpc/*:php_plugin=False
grpc/*:python_plugin=False
grpc/*:ruby_plugin=False
# Lightweight protobuf
#protobuf/*:lite=True
